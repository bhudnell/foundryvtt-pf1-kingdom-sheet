<form class="{{ cssClass }}" data-tooltip-class="pf1" autocomplete="off">
  {{! Sheet Navigation }}
  <nav class="sheet-navigation tabs" data-group="primary">
    <a class="item" data-tab="summary" data-group="primary">{{localize "PF1.Summary"}}</a>
    <a class="item" data-tab="features" data-group="primary">{{ localize "PF1KS.Features" }}</a>
    <a class="item" data-tab="magic-items" data-group="primary">{{ localize "PF1KS.MagicItems" }}</a>
    <a class="item" data-tab="notes" data-group="primary">{{localize "PF1.Notes"}}</a>
  </nav>

  {{! Sheet Body }}
  <section class="primary-body">
    {{! Summary Tab }}
    <div class="tab summary" data-group="primary" data-tab="summary">
      {{~> settlement-lite-sheet-summary}}
    </div>

    {{! Features Tab }}
    <div class="tab features" data-group="primary" data-tab="features">
      {{~> settlement-lite-sheet-features}}
    </div>

    {{! Magic Items Tab }}
    <div class="tab magic-item" data-group="primary" data-tab="magic-items">
      {{~> settlement-lite-sheet-magic-items}}
    </div>

    {{! Notes Tab }}
    <div class="tab actor-notes" data-group="primary" data-tab="notes">
      <div class="primary-content">
        {{editor enrichedNotes target="system.notes.value" button=true editable=editable engine="prosemirror"}}
      </div>
    </div>
  </section>
</form>
