<div class="magic-item-section item-groups-list">
  {{#each magicItems}}
  <div class="magic-item-container" data-type="{{ key }}">
    <div class="info-box-header" data-tooltip-extended="magic-items.{{ key }}">
      <h3>
        {{#if error}}
        <i class="fa-solid fa-triangle-exclamation" data-tooltip="{{ error }}"></i>
        {{/if}}
        <span>{{ label }}</span>
      </h3>
      <div class="info-box-joined">
        <div class="info-box">
          <h5>{{localize "PF1.Current"}}</h5>
          <span class="value">{{ current }}</span>
        </div>
        <div class="info-box">
          <h5>{{localize "PF1.MaxShort"}}</h5>
          <span class="value text-box direct" name="system.magicItems.{{ key }}.max" data-dtype="Number">
            {{ max }}
          </span>
        </div>
      </div>
    </div>

    {{#each items as |item iidx|}}
    <div class="magic-item" data-item-id="{{ iidx }}">
      <input type="text" name="system.magicItems.{{../key}}.items.{{ iidx }}" value="{{ this }}" />
      <a class="magic-item-delete" data-tooltip="PF1.DeleteItem"><i class="fas fa-trash"></i></a>
    </div>
    {{/each}}
  </div>
  {{/each}}
</div>
